DATA_DIR=data
UPLOADS_DIR=data/uploads
PROCESSED_DIR=data/processed
REPORTS_DIR=data/reports
VECTOR_DB_DIR=data/vector_db

# Streamlit backend URL.
# Local run:
BACKEND_URL=http://localhost:8000
# Docker Compose sets BACKEND_URL=http://backend:8000 for the frontend service.

# Optional LLM provider settings. Leave OPENROUTER_API_KEY empty to use deterministic fallbacks.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# Speech-to-text settings for faster-whisper.
# Set STT_USE_FAKE_TRANSCRIBER=true for tests/local demos without model downloads.
STT_MODEL_SIZE=tiny
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_USE_FAKE_TRANSCRIBER=false

# YouTube transcript settings.
# Set YOUTUBE_USE_FAKE_TRANSCRIPT=true for tests/local demos without internet access.
YOUTUBE_USE_FAKE_TRANSCRIPT=false
YOUTUBE_LANGUAGES=ru,en
